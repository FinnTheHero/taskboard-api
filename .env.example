NODE_ENV=development
PORT=4000

# Railway: DATABASE_URL is auto-provided when a Postgres plugin is attached to your service.
# For local dev: fill in your local Postgres connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/taskboard

CORS_ORIGIN=http://localhost:5173

# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me-at-least-16-characters
JWT_EXPIRES_IN=7d

# Optional — only needed if email notifications are enabled
RESEND_API_KEY=
RESEND_FROM=TaskBoard <noreply@example.com>
